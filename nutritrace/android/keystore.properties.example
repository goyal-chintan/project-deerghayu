# Release signing credentials for assembleRelease.
#
# Copy this file to `keystore.properties` (alongside this one, in the
# android/ directory) and fill in your own values. The real
# keystore.properties is gitignored and never committed.
#
# Without this file, assembleRelease falls back to debug signing —
# fine for local testing, NOT suitable for distribution.

# Path to the .keystore file you generated with keytool. Absolute path
# is recommended so the build works from any CWD.
storeFile=/home/you/.android/nutritrace-release.keystore

# Password you set when generating the keystore.
storePassword=CHANGE_ME

# Alias you used for the key inside the keystore.
keyAlias=nutritrace

# Password for the key (often the same as storePassword).
keyPassword=CHANGE_ME
